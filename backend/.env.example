# Server
PORT=5001

# Database (use DATABASE_URL or PG* vars)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=postgres
DB_SSL=false

# JWT (required in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Super Admin (required in production; set in Dokploy → Environment)
# In development, if unset, defaults to superadmin/superadmin for convenience.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
