// Prisma schema for Kamel System - User Management Module
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  Company
  ServiceCenter
}

enum Role {
  Admin
  Supervisor
  Employee
}

model Location {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  locationAr  String?  @map("location_ar")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users  User[]
  groups Group[]

  @@map("work_locations")
}

model Shift {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  shiftAr        String?  @map("shift_ar")
  startTime      DateTime @map("start_time") @db.Time
  endTime        DateTime @map("end_time") @db.Time
  isForEmployee  Boolean  @default(true) @map("is_for_employee")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("shifts")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  fullName        String    @map("full_name")
  fullNameAr      String?   @map("full_name_ar")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  phone           String?
  userType        UserType  @map("user_type")
  role            Role      @default(Employee)
  jobTitle        String?   @map("job_title")
  shiftId         String?   @map("shift_id") @db.Uuid
  locationId      String?   @map("location_id") @db.Uuid
  supervisorId    String?   @map("supervisor_id") @db.Uuid
  serviceCenterId String?   @map("service_center_id") @db.Uuid
  isActive        Boolean   @default(true) @map("is_active")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  isSuperAdmin    Boolean   @default(false) @map("is_super_admin")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  shift           Shift?    @relation(fields: [shiftId], references: [id])
  location        Location? @relation(fields: [locationId], references: [id])
  supervisor       User?    @relation("UserSupervisor", fields: [supervisorId], references: [id])
  subordinates     User[]   @relation("UserSupervisor")
  auditLogs        AuditLog[]
  activityLogs     ActivityLog[]
  userPermissions  UserPermission[]
  userGroups       UserGroup[]

  @@index([email])
  @@index([isDeleted, isActive])
  @@index([supervisorId])
  @@index([serviceCenterId])
  @@index([shiftId])
  @@index([locationId])
  @@map("users")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  action    String
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  module      String?  @map("module")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userPermissions    UserPermission[]
  defaultPermissions DefaultPermission[]
  groupPermissions   GroupPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model DefaultPermission {
  id           String   @id @default(uuid()) @db.Uuid
  userType     UserType @map("user_type")
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userType, permissionId])
  @@index([userType])
  @@map("default_permissions")
}

model Group {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @map("name")
  locationId  String?   @map("location_id") @db.Uuid
  description String?   @map("description")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  location   Location?        @relation(fields: [locationId], references: [id], onDelete: SetNull)
  permissions GroupPermission[]
  userGroups UserGroup[]

  @@index([locationId])
  @@map("groups")
}

model GroupPermission {
  id           String   @id @default(uuid()) @db.Uuid
  groupId      String   @map("group_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([groupId, permissionId])
  @@index([groupId])
  @@map("group_permissions")
}

model UserGroup {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@map("user_groups")
}
