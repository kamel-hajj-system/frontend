{
  "name": "kamel-system-backend",
  "version": "1.0.0",
  "description": "Backend for Kamel System - Express + PostgreSQL API server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:local": "PORT=5001 nodemon src/index.js",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "prisma migrate deploy",
    "db:ensure": "node scripts/ensure-migrations.js",
    "db:setup": "node scripts/ensure-migrations.js && node modules/users/seeds/run-seed.js",
    "db:seed": "node modules/users/seeds/run-seed.js",
    "test": "node --test modules/users/tests/*.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "supertest": "^6.3.4"
  }
}

